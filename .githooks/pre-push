#!/bin/bash
# OpenClaw Trader — Pre-Push Guard

R=$(printf '\033[0;31m')
G=$(printf '\033[0;32m')
Y=$(printf '\033[1;33m')
C=$(printf '\033[0;36m')
M=$(printf '\033[0;35m')
D=$(printf '\033[2m')
B=$(printf '\033[1m')
N=$(printf '\033[0m')

W=62

row() {
  local text="$1" overhead="${2:-0}" color="${3:-$C}"
  local pad=$((W - ${#text} + overhead))
  [ $pad -lt 0 ] && pad=0
  printf "${color}║${N} %s%*s ${color}║${N}\n" "$text" "$pad" ""
}

hbar() { local color="${1:-$C}"; printf "${color}╠"; printf '═%.0s' $(seq 1 $((W+2))); printf "╣${N}\n"; }
top()  { local color="${1:-$C}"; printf "${color}╔"; printf '═%.0s' $(seq 1 $((W+2))); printf "╗${N}\n"; }
bot()  { local color="${1:-$C}"; printf "${color}╚"; printf '═%.0s' $(seq 1 $((W+2))); printf "╝${N}\n"; }
blank(){ row "" 0 "${1:-$C}"; }

remote="$1"
url="$2"

while read local_ref local_sha remote_ref remote_sha; do
  branch=$(echo "$remote_ref" | sed 's|refs/heads/||')

  if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then

    if [ "$ALLOW_MAIN_PUSH" = "1" ]; then
      echo ""
      top "$Y"
      row "${B}OVERRIDE ACTIVE${N} — pushing directly to ${M}${branch}${N}" 21 "$Y"
      bot "$Y"
      echo ""
      continue
    fi

    echo ""
    top "$R"
    blank "$R"
    row "${B}PUSH BLOCKED${N} — Direct push to ${M}${branch}${N} is not allowed" 21 "$R"
    blank "$R"
    hbar "$R"
    blank "$R"
    row "${D}WHY:${N}" 4 "$R"
    row "Pushing to ${M}main${N} = deploying to ${B}production${N}" 17 "$R"
    row "All changes go through a Pull Request first so" 0 "$R"
    row "you get:" 0 "$R"
    row "  - A preview/test before it goes live" 0 "$R"
    row "  - Automated lint + build checks (CI)" 0 "$R"
    row "  - A record of what changed and why" 0 "$R"
    blank "$R"
    row "${D}WHAT TO DO INSTEAD:${N}" 4 "$R"
    blank "$R"
    row "  ${G}git checkout -b my-feature${N}      ${D}# create a branch${N}" 22 "$R"
    row "  ${G}git push -u origin my-feature${N}   ${D}# push the branch${N}" 22 "$R"
    row "  ${D}Then open a PR on GitHub to merge into main.${N}" 4 "$R"
    blank "$R"
    row "${D}EMERGENCY:${N} ${Y}ALLOW_MAIN_PUSH=1 git push origin main${N}" 17 "$R"
    blank "$R"
    bot "$R"
    echo ""
    exit 1

  else
    echo ""
    top "$G"
    blank "$G"
    row "${B}PUSHING${N} branch ${M}${branch}${N} to ${D}${remote}${N}" 21 "$G"
    blank "$G"
    row "${D}WHAT HAPPENS NEXT:${N}" 4 "$G"
    row "1. Open a PR on GitHub to merge into main" 0 "$G"
    row "2. CI runs lint + secret scan checks" 0 "$G"
    row "3. Merge the PR = deploy to production" 0 "$G"
    blank "$G"
    bot "$G"
    echo ""
  fi
done

exit 0
