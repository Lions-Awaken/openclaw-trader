#!/bin/bash
# OpenClaw Trader вЂ” Pre-Commit Guard

R=$(printf '\033[0;31m')
G=$(printf '\033[0;32m')
Y=$(printf '\033[1;33m')
C=$(printf '\033[0;36m')
M=$(printf '\033[0;35m')
D=$(printf '\033[2m')
B=$(printf '\033[1m')
N=$(printf '\033[0m')

W=62

row() {
  local text="$1" overhead="${2:-0}"
  local pad=$((W - ${#text} + overhead))
  [ $pad -lt 0 ] && pad=0
  printf "${C}в•‘${N} %s%*s ${C}в•‘${N}\n" "$text" "$pad" ""
}

bar()  { printf "${C}в• "; printf 'в•ђ%.0s' $(seq 1 $((W+2))); printf "в•Ј${N}\n"; }
top()  { printf "${C}в•”"; printf 'в•ђ%.0s' $(seq 1 $((W+2))); printf "в•—${N}\n"; }
bot()  { printf "${C}в•љ"; printf 'в•ђ%.0s' $(seq 1 $((W+2))); printf "в•ќ${N}\n"; }
blank(){ row ""; }

# в”Ђв”Ђ Gather info в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
FILE_COUNT=$(echo "$STAGED_FILES" | grep -c '[^[:space:]]')
PY_COUNT=$(echo "$STAGED_FILES" | grep -c '\.py$' || true)
BRANCH=$(git branch --show-current)

# в”Ђв”Ђ Banner в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo ""
top
row "${B}OPENCLAW TRADER${N} вЂ” Pre-Commit Guard" 8
bar
blank
row "${D}Branch:${N}  ${M}${BRANCH}${N}" 16
row "${D}Files:${N}   ${FILE_COUNT} staged  ${D}(${PY_COUNT} Python)${N}" 12
blank
row "${D}WHAT THIS DOES:${N}" 4
row "Checks your code for leaked secrets and lint errors"
row "${D}before${N} they get saved into git history. Think of it" 8
row "like a bouncer checking IDs at the door."
blank
bar
row "${B}CHECK                              STATUS${N}" 8
bar

# в”Ђв”Ђ Check 1: Secret Scanner в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SCAN_OUTPUT=$(bash scripts/scan-secrets.sh $STAGED_FILES 2>&1)
SCAN_EXIT=$?

if [ $SCAN_EXIT -eq 0 ]; then
  row "Secret Scanner ........................ ${G}PASS${N}" 9
  row "${D}No passwords, API keys, or tokens found${N}" 4
  SCAN_OK=true
else
  row "Secret Scanner ........................ ${R}FAIL${N}" 9
  blank
  echo "$SCAN_OUTPUT" | grep -v "SCAN_RESULT" | while IFS= read -r line; do
    [ -z "$line" ] && continue
    row "$line"
  done
  SCAN_OK=false
fi

blank

# в”Ђв”Ђ Check 2: Ruff (Python linting) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [ "$PY_COUNT" -gt 0 ]; then
  PY_FILES=$(echo "$STAGED_FILES" | grep '\.py$')
  if command -v ruff &>/dev/null; then
    LINT_OUTPUT=$(echo "$PY_FILES" | xargs ruff check --no-fix 2>&1)
    LINT_EXIT=$?

    if [ $LINT_EXIT -eq 0 ]; then
      row "Ruff (Python lint) .................... ${G}PASS${N}" 9
      row "${D}No lint errors in Python files${N}" 4
      LINT_OK=true
    else
      ERROR_COUNT=$(echo "$LINT_OUTPUT" | grep -cE "^[^ ]+" || true)
      row "Ruff (Python lint) .................... ${R}FAIL${N}" 9
      row "${R}${ERROR_COUNT} issue(s) found вЂ” fix before committing${N}" 9
      LINT_OK=false
    fi
  else
    row "Ruff (Python lint) .................... ${D}SKIP${N}" 4
    row "${D}ruff not installed (pip install ruff)${N}" 4
    LINT_OK=true
  fi
else
  row "Ruff (Python lint) .................... ${D}SKIP${N}" 4
  row "${D}No Python files in this commit${N}" 4
  LINT_OK=true
fi

blank

# в”Ђв”Ђ Result в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
bar

if [ "$SCAN_OK" = true ] && [ "$LINT_OK" = true ]; then
  blank
  row "${G}${B}ALL CHECKS PASSED${N}  вЂ” commit proceeding" 13
  blank
  row "${D}WHAT HAPPENS NEXT:${N}" 4
  row "Your changes are now saved locally. To share them:"
  row "  ${G}git push -u origin ${BRANCH}${N}" 9
  row "Then open a PR to merge into main."
  blank
  bot
  echo ""
  exit 0
else
  blank
  row "${R}${B}COMMIT BLOCKED${N}  вЂ” fix the issues above" 13
  blank
  row "${D}WHAT THIS MEANS:${N}" 4
  row "Nothing was committed. Your files are still staged"
  row "and ready вЂ” fix the issue, then run ${Y}git commit${N} again." 9
  blank
  row "${D}False positive? Use:${N} ${Y}git commit --no-verify${N}" 13
  blank
  bot
  echo ""
  exit 1
fi
